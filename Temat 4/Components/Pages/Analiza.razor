@page "/sentiment"
@rendermode InteractiveServer

@using Lab4

<PageTitle>Analiza sentymentu</PageTitle>

<h1>Analiza sentymentu</h1>

<div class="mb-3">

    <label class="form-label">Wpisz tekst:</label>

    <textarea class="form-control"
              rows="5"
                  @bind="userInput">
    </textarea>

    </div>

    <button class="btn btn-primary"
            @onclick="AnalyzeSentiment">
        Analizuj
    </button>

    @if (prediction is not null)
    {
        <div class="alert alert-info mt-3">

            <p>
                <strong>Etykieta:</strong>
                @prediction.PredictedLabel
            </p>

            <p>
                <strong>Pewność:</strong>
                @($"{prediction.Score.Max() * 100:0.00}%")
            </p>

        </div>
    }

@code {

    private string userInput = "";

    private Model.ModelOutput? prediction;

    private void AnalyzeSentiment()
    {
        if (!string.IsNullOrWhiteSpace(userInput))
        {
            // dane wejściowe dla modelu
            var input = new Model.ModelInput
            {
                Text = userInput
            };

            prediction = Model.Predict(input);
        }
    }
}